# Copy this file to .streamlit/secrets.toml and fill in your values
# DO NOT commit the actual secrets.toml file (it's in .gitignore)

[snowflake]
account = "your_account_identifier"
user = "your_username"
password = "your_password"
warehouse = "SUPPLIER_ANALYTICS_WH"
database = "SUPPLIER_DW"
schema = "GOLD"
role = "SUPPLIER_ANALYST_ROLE"
